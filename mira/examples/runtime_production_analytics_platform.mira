  branch state_ok b3(svc, req, body, value, state) b4(svc, req, body)

block b3(svc:u64, req:own[buf[u8]], body:own[buf[u8]], value:u32, state:u32)
  v11:u32 = add value state
  v12:u32 = service_health_status svc
  v13:u32 = add v11 v12
  jump b5(svc, req, body, v13)

block b4(svc:u64, req:own[buf[u8]], body:own[buf[u8]])
  v15:b1 = service_close svc
  v16:b1 = drop body
  v17:b1 = drop req
  return 0u32

block b5(svc:u64, req:own[buf[u8]], body:own[buf[u8]], status:u32)
  v18:b1 = service_close svc
  v19:b1 = drop body
