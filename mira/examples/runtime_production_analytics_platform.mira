func process_analytics_job
arg job:u32
ret u32
eff spawn clock
cap clock("monotonic")
spec kind=runtime constraints=[worker,analytics,job,channel]
block b0
  v0:b1 = rt_cancelled
  branch v0 b1(job) b2(job)

block b1(job:u32)
  return 0u32

block b2(job:u32)
  v1:b1 = task_sleep_ms 1u32
  v2:u32 = add job job
  v3:u32 = add v2 job
  return v3
end

