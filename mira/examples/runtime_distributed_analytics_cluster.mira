block b13(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], replay_a:own[buf[u8]])
  v37:u32 = coord_load_u32 coord checkpoint
  v38:u32 = add v37 1u32
  v39:u64 = stream_replay_open streamh v38
  v40:own[buf[u8]] = stream_replay_next v39
  v41:u32 = buf_parse_u32 v40
  v42:b1 = agg_add_u64 aggh 13u64
  v43:u32 = stream_replay_offset v39
  v44:b1 = coord_store_u32 coord checkpoint v43
  v45:b1 = stream_replay_close v39
  v46:u64 = agg_sum_u64 aggh
  v47:b1 = eq v41 13u32
  branch v47 b16(service, place, lease, coord, streamh, aggh, seed_a, seed_b, replay_a, v40, v42, v43, v44, v45, v46) b17(service, place, lease, coord, streamh, aggh, seed_a, seed_b, replay_a, v40)

block b14(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]])
  v48:b1 = agg_close aggh
  v49:b1 = stream_close streamh
  v50:b1 = coord_close coord
  v51:b1 = lease_close lease
  v52:b1 = placement_close place
  v53:b1 = service_close service
  v54:b1 = drop seed_b
  v55:b1 = drop seed_a
