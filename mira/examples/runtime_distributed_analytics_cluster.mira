module runtime.distributed.analytics.cluster@1
target native

func replay_cluster_checkpoint
ret u8
eff alloc queue service fs.write
cap queue("/tmp/mira_2_4_analytics.stream")
cap service("distributed-analytics")
cap fs("/tmp/mira_2_4_analytics.stream")
spec kind=worker constraints=[distributed,analytics,checkpoint,replay]
block b0
  v0:own[buf[u8]] = alloc arena 0u32
  v1:view[buf[u8]] = view v0
  v2:b1 = fs_write_all v1
  v3:b1 = drop v0
  v4:u64 = service_open
