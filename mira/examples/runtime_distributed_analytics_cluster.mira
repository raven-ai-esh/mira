  v10:b1 = lease_release v6 2u32
  v11:b1 = lease_release v6 3u32
  v12:own[buf[u8]] = buf_lit 11
  v13:own[buf[u8]] = buf_lit 13
  v14:u32 = shard_route_u32 v12 2u32
  v15:b1 = placement_assign v5 v14 2u32
  branch v15 b1(v4, v5, v6, v7, v8, v9, v12, v13, v14) b14(v4, v5, v6, v7, v8, v9, v12, v13)

block b1(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], shard:u32)
