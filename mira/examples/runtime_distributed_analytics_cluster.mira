block b5(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], seq_b:u32)
  v23:b1 = eq seq_b 2u32
  branch v23 b6(service, place, lease, coord, streamh, aggh, seed_a, seed_b) b14(service, place, lease, coord, streamh, aggh, seed_a, seed_b)

block b6(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]])
  v24:u32 = coord_load_u32 coord checkpoint
  v25:u32 = add v24 1u32
  v26:u64 = stream_replay_open streamh v25
  v27:own[buf[u8]] = stream_replay_next v26
  v28:u32 = buf_parse_u32 v27
  v29:b1 = agg_add_u64 aggh 11u64
  v30:u32 = stream_replay_offset v26
  v31:b1 = coord_store_u32 coord checkpoint v30
  v32:b1 = stream_replay_close v26
  branch v29 b7(service, place, lease, coord, streamh, aggh, seed_a, seed_b, v27, v28, v30, v31, v32) b15(service, place, lease, coord, streamh, aggh, seed_a, seed_b, v27)

block b7(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], replay_a:own[buf[u8]], parsed_a:u32, checkpoint_a:u32, save_a:b1, close_a:b1)
  v33:b1 = eq parsed_a 11u32
