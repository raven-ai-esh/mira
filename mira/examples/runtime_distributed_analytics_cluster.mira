block b15(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], replay_a:own[buf[u8]])
  v56:b1 = agg_close aggh
  v57:b1 = stream_close streamh
  v58:b1 = coord_close coord
  v59:b1 = lease_close lease
  v60:b1 = placement_close place
  v61:b1 = service_close service
  v62:b1 = drop replay_a
  v63:b1 = drop seed_b
  v64:b1 = drop seed_a
