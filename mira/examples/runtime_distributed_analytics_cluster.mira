block b16(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], replay_a:own[buf[u8]], replay_b:own[buf[u8]], agg_ok:b1, checkpoint_b:u32, save_b:b1, close_b:b1, sum:u64)
  branch agg_ok b18(service, place, lease, coord, streamh, aggh, seed_a, seed_b, replay_a, replay_b, checkpoint_b, save_b, close_b, sum) b17(service, place, lease, coord, streamh, aggh, seed_a, seed_b, replay_a, replay_b)

block b17(service:u64, place:u64, lease:u64, coord:u64, streamh:u64, aggh:u64, seed_a:own[buf[u8]], seed_b:own[buf[u8]], replay_a:own[buf[u8]], replay_b:own[buf[u8]])
  v65:b1 = agg_close aggh
  v66:b1 = stream_close streamh
  v67:b1 = coord_close coord
  v68:b1 = lease_close lease
  v69:b1 = placement_close place
  v70:b1 = service_close service
  v71:b1 = drop replay_b
  v72:b1 = drop replay_a
  v73:b1 = drop seed_b
  v74:b1 = drop seed_a
