module runtime.agent.recovery.service@1
target native

func slow_job
arg steps:u32
ret u32
eff spawn clock
cap clock("monotonic")
spec kind=runtime constraints=[timer,cancel]
block b0
  jump b1(0u32, steps)

block b1(i:u32, n:u32)
  v0:b1 = rt_cancelled
  branch v0 b2(i, n) b3(i, n)

block b2(i:u32, n:u32)
  return 999u32

block b3(i:u32, n:u32)
  v1:b1 = lt i n
  branch v1 b4(i, n) b5(i, n)

block b4(i:u32, n:u32)
  v2:b1 = task_sleep_ms 2u32
  v3:u32 = add i 1u32
  jump b1(v3, n)

block b5(i:u32, n:u32)
  return i
end

func maintained_agent_recovery_status
ret u32
eff service spawn clock
cap service("agent-platform-recovery")
cap clock("monotonic")
spec kind=service constraints=[agent_platform,maintained,recovery,portable_native]
block b0
  v0:u64 = service_open
  v1:u64 = rt_open 1u32
  v2:u64 = rt_spawn_u32 v1 slow_job 20u32
  v3:b1 = task_sleep_ms 5u32
  v4:b1 = rt_cancel v2
  v5:u32 = rt_join_u32 v2
  v6:u32 = service_health_status v0
  v7:u32 = add v5 v6
  v8:b1 = rt_task_close v2
  v9:b1 = rt_shutdown v1 50u32
  v10:b1 = rt_close v1
  v11:b1 = service_close v0
  return v7

test t0
  out 1199u32
end
