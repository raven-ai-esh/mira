module bits.ops@1
target native

func scramble_u32
arg x:u32
ret u32
eff pure
spec kind=bitmix constraints=[pure,no_alloc]
block b0
  v0:u32 = shl x 2u32
  v1:u32 = bor v0 3u32
  v2:u32 = band v1 31u32
  v3:u32 = bxor v2 7u32
  v4:u32 = shr v3 1u32
  v5:u32 = bnot v4
  return v5
test t0
  in x=10u32
  out 4294967289u32
test t1
  in x=0u32
  out 4294967293u32
end
